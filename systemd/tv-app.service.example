[Unit]
Description=TV Node App
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=user
WorkingDirectory=/home/user/tv
Environment=NODE_ENV=production
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/user/.Xauthority
Environment=XDG_RUNTIME_DIR=/run/user/1000
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
Environment=PULSE_SERVER=unix:/run/user/1000/pulse/native
Environment=KIOSK_URL=http://localhost:3000
Environment=AUDIO_STACK=pipewire
Environment=KIOSK_PROFILE_DIR=/tmp/kiosk-chromium-profile
ExecStart=/usr/bin/node /home/user/tv/server.js
ExecStartPost=/home/user/tv/scripts/restart-kiosk-browser.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
