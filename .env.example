# Server
NODE_ENV=development
PORT=3000
REMOTE_PORT=3001
REMOTE_CONTROL_URL=

# System
ALSA_BEEP_DEVICE=default
CHROMIUM_DEBUG_ORIGIN=http://127.0.0.1:9222
CHROMIUM_BIN=/usr/bin/chromium

# Logging And Diagnostics
ENABLE_FILE_LOGS=0
ENABLE_CLIENT_DIAGNOSTICS=0
VERBOSE_API_LOGGING=0
API_SLOW_REQUEST_THRESHOLD_MS=1500
MAX_STORED_MESSAGES=1000

# Channels
CHANNEL11_URL=https://kancdn.medonecdn.net/livehls/oil/kancdn-live/live/kan_edu/live.livx/playlist.m3u8?renditions&fmp4
CHANNEL11_FALLBACK_URLS=
CHANNEL12_URL=https://mako-streaming.akamaized.net/n12/hls/live/2041434/n12_b/index.m3u8?b-in-range=400-800&hdnea=st=1773771605~exp=1773772505~acl=/*~hmac=523effce8a4493c4d8be7626e9184e8a2bab5db19b4ef5663e2f7f813aa1b955
CHANNEL12_FALLBACK_URLS=
CHANNEL13_URL=https://d2xg1g9o5vns8m.cloudfront.net/out/v1/0855d703f7d5436fae6a9c7ce8ca5075/index.m3u8
CHANNEL13_FALLBACK_URLS=
CHANNEL16_URL=rtsp://user:password@camera.local:554/Streaming/Channels/102
CHANNEL16_FALLBACK_URLS=
DEFAULT_CHANNEL_ID=13

# Weather
WEATHER_CITIES={"bat-hefer":{"name":"Bat-Hefer","query":"Bat Hefer","lat":32.33307,"lon":35.01272,"aliases":["Bat Hefer","בת חפר"]},"yokneam":{"name":"Yokneam","aliases":["Yokneam","Yoqneam","Yokneam Illit","יקנעם","יוקנעם"]}}
DEFAULT_WEATHER_CITY=bat-hefer
# Comma-separated priority cities for alert location ordering.
# Example: if alerts contain A,B,C,D and D is listed here, they will be shown as D,A,B,C.
# You can use city ids, display names, or aliases from WEATHER_CITIES.
WEATHER_CITIES_PRIORITY=בת חפר,תל אביב,מודיעין,ראשון לציון
TIMEZONE=Asia/Jerusalem

# Alerts
ALERTS_REFRESH_MS=15000
PIKUD_HAOREF_CACHE_MS=15000
PIKUD_HAOREF_HISTORY_LIMIT=30
PIKUD_HAOREF_CURRENT_URL=https://www.oref.org.il/WarningMessages/alert/alerts.json
PIKUD_HAOREF_HISTORY_URL=
PIKUD_HAOREF_REFERER=https://www.oref.org.il/12481-he/Pakar.aspx
EMERGENCY_CONTACTS=[{"name":"משטרה","number":"100","primary":true},{"name":"אמבולנס","number":"101","primary":true},{"name":"מכבי אש","number":"102","primary":true}]

# News
NEWS_CACHE_MS=60000
NEWS_ITEMS_PER_SOURCE=12
NEWS_MAX_AGE_MINUTES=1440
YNET_BREAKING_NEWS_URL=https://www.ynet.co.il/
MAKO_NEWS_RSS_URL=https://rcs.mako.co.il/rss/31750a2610f26110VgnVCM1000005201000aRCRD.xml
ISRAEL_HAYOM_NEWS_URL=https://www.israelhayom.co.il/
KAN_BREAKING_NEWS_URL=https://www.kan.org.il/
KAN_HEADLINES_URL=https://www.kan.org.il/lobby/news/

# Playback
DEFAULT_VOLUME=70
HLS_LOW_LATENCY_MODE=0
HLS_LIVE_SYNC_DURATION_COUNT=12
HLS_LIVE_MAX_LATENCY_DURATION_COUNT=20
HLS_BACK_BUFFER_LENGTH=90
HLS_MAX_BUFFER_LENGTH=120
HLS_MAX_MAX_BUFFER_LENGTH=180
HLS_MAX_BUFFER_HOLE=1.5
HLS_HIGH_BUFFER_WATCHDOG_PERIOD=4
RTSP_RELAY_SEGMENT_DURATION=2
RTSP_RELAY_SEGMENT_COUNT=6
RTSP_RELAY_STARTUP_TIMEOUT_MS=12000
RTSP_RELAY_IDLE_TIMEOUT_MS=120000

# TV News UI
TV_NEWS_PAGE_LIMIT=80
TV_NEWS_MAX_AGE_MINUTES=360
ALERTS_NEWS_SCROLL_DURATION_MS=30000
ALERTS_NEWS_SCROLL_PAUSE_MS=2500
